{
  "name": "clima-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "node -e \"const fs = require('fs'); const p = 'node_modules/expo-sqlite/expo-module.config.json'; if (fs.existsSync(p)) fs.unlinkSync(p);\"",
    "build": "expo export --platform web"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "expo": "~51.0.0",
    "expo-location": "~17.0.1",
    "expo-status-bar": "~1.12.1",
    "expo-sqlite": "~14.0.3",
    "react": "18.2.0",
    "react-native": "0.74.1"
  },
  "engines": {
    "node": "20.x"
  },
  "private": true
}